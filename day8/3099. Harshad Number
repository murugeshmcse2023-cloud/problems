class Solution {
    public int sumOfTheDigitsOfHarshadNumber(int n) {
        int originalnum=n;
        int div = 1;
        int sum =0;
        while(div<=n){
            int ld = (n%(div*10))/div;
            div=div*10;
            sum = sum + ld;    
        }
        if(originalnum%sum==0) return sum;
        return -1;
    }
}
