class Solution {
    public int sumOfEncryptedInt(int[] nums) {
        int ans = 0;

        for (int num : nums) {
            int temp = num;
            int max = 0;
            int digits = 0;

            while (temp > 0) {
                max = Math.max(max, temp % 10);
                digits++;
                temp /= 10;
            }

            int encrypted = 0;
            while (digits-- > 0) {
                encrypted = encrypted * 10 + max;
            }

            ans += encrypted;
        }

        return ans;
    }
}
